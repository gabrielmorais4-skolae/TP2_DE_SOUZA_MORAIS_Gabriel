<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="ProductsPU" transaction-type="JTA">
        <description>Persistence Unit for Products API</description>

        <class>com.formation.products.model.Product</class>

        <properties>
            <!-- Datasource JNDI configuré sur le serveur Payara -->
            <property name="jakarta.persistence.dataSource" value="jdbc/ProductsDS"/>

            <!-- Création automatique du schéma en dev (create-drop, create, update, validate, none) -->
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>

            <!-- Hibernate / EclipseLink options -->
            <property name="eclipselink.logging.level" value="INFO"/>
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
        </properties>
    </persistence-unit>

</persistence>
